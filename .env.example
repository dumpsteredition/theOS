# Optional. Absolute production URL used for metadata and social previews.
# Vercel can also provide VERCEL_PROJECT_PRODUCTION_URL or VERCEL_URL automatically.
BRUMBLEYOS_SITE_URL=

# Optional. Discord incoming webhook used for BrumbleyOS Add Contact form submissions.
BRUMBLEYOS_DISCORD_WEBHOOK_URL=

# Optional. Generic inbox capture webhook used for inbox chat/message forwarding.
# Supported modes: generic, slack, discord.
BRUMBLEYOS_INBOX_WEBHOOK_MODE=generic
BRUMBLEYOS_INBOX_WEBHOOK_URL=
BRUMBLEYOS_INBOX_WEBHOOK_BEARER_TOKEN=
